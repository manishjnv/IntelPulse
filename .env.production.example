# =============================================
# IntelPulse TI Platform — Production Environment
# =============================================
# SECURITY: Never commit this file with real values!
# Copy to .env and fill in production secrets.

# ── General ──────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# CRITICAL: Generate with: openssl rand -hex 32
SECRET_KEY=

# ── Domain Configuration ────────────────────────────────
DOMAIN=intelpulse.tech
DOMAIN_UI=https://intelpulse.tech
DOMAIN_API=https://intelpulse.tech

# ── PostgreSQL + TimescaleDB ─────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ti_platform
POSTGRES_USER=ti
# CRITICAL: Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# ── Redis ────────────────────────────────────────────────
# CRITICAL: Generate with: openssl rand -base64 32
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── OpenSearch ───────────────────────────────────────────
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
# CRITICAL: Generate with: openssl rand -base64 32
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false

# ── Authentication ───────────────────────────────────────
JWT_EXPIRE_MINUTES=480

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email OTP (Optional) ─────────────────────────────────
EMAIL_OTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@intelpulse.tech
SMTP_FROM_NAME=IntelPulse

# ── Feed API Keys ────────────────────────────────────────
NVD_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
IPINFO_TOKEN=

# ── AI Configuration ─────────────────────────────────────
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
AI_TIMEOUT=30
AI_ENABLED=true

# AI Fallback Providers (Optional)
CEREBRAS_API_KEY=
HF_API_KEY=

# ── CORS Configuration ───────────────────────────────────
# SECURITY: Only list trusted domains, never use wildcards
CORS_ORIGINS=https://intelpulse.tech,https://www.intelpulse.tech
