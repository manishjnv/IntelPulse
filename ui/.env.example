# =============================================
# IntelPulse UI — Environment Variables
# =============================================
# Copy this file to .env.local and fill in values.

# ── API Configuration ────────────────────────────────────
# Backend API URL (used for server-side API calls)
BACKEND_URL=http://localhost:8000

# ── Public Environment Variables ─────────────────────────
# These are exposed to the browser (prefix with NEXT_PUBLIC_)

# API URL for client-side requests
NEXT_PUBLIC_API_URL=http://localhost:8000

# Application name
NEXT_PUBLIC_APP_NAME=IntelPulse

# ── Demo Mode (for codethon/reviewer access) ────────────
# Set to "true" to display demo mode banner
# WARNING: Only enable for demo/evaluation environments
NEXT_PUBLIC_DEMO_MODE=false
